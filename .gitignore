node_modules/
www/
supabase/.temp/
temporary screenshots/
*.tmp.json
e2e-test-creds.json

# Firebase service account keys (private key — must never be committed;
# contents go into the FIREBASE_SERVICE_ACCOUNT_JSON Supabase secret instead.
# google-services.json is NOT secret and is intentionally not listed here —
# it only contains public identifiers and needs to be committed for
# Codemagic's Android build to pick it up.)
android/app/*firebase-adminsdk*.json

# Safety net for any stray credential files dropped in the project root or
# native folders during setup — should never actually live here permanently.
*ecret*ey*.txt
*.pem
*.p12

# Release signing keystore — permanent credential, never committed. Back this
# up (and its password) somewhere safe outside this repo; losing it means
# losing the ability to publish updates to the app under the same listing.
*.keystore
*.jks
android/keystore.properties

# Android build artifacts (keep the project files, ignore generated output)
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/app/release/
android/captures/

# iOS build artifacts
ios/App/Pods/
ios/App/build/
ios/App/DerivedData/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/

*.log
.DS_Store
*.apk
*.ipa
*.aab

.vercel
