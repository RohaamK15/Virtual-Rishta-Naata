<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Lets Stripe Checkout (opened in an external browser tab, not
                 the app's own WebView, so we stay compliant with Apple/Google
                 payment policy) hand control back to the app once payment
                 completes or is cancelled.

                 This must be a verified HTTPS App Link (not a custom URL
                 scheme) — Chrome on Android refuses to hand off to an
                 external app for a navigation that isn't tied to a direct
                 user gesture, and Stripe's post-payment redirect fires
                 asynchronously well after the original "Pay" click, so a
                 custom scheme here would just get silently blocked. A
                 verified App Link is intercepted by the OS before that
                 gesture check ever applies. Verification requires
                 /.well-known/assetlinks.json on this exact host, listing
                 this app's signing cert fingerprint(s). -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="virtualrishtanaata.com" android:pathPrefix="/signup.html" />
                <data android:scheme="https" android:host="virtualrishtanaata.com" android:pathPrefix="/services.html" />
                <data android:scheme="https" android:host="virtualrishtanaata.com" android:pathPrefix="/consultation-confirmed.html" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
</manifest>
